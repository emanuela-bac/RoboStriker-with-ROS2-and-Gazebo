<?xml version="1.0"?>
<!-- 
  URDF file for a simple differential drive robot with camera
  
  The robot consists of:
  - A rectangular base (chassis)
  - Two driven wheels for differential drive
  - One caster wheel for stability
  - A camera sensor mounted on front
  - A pusher/bumper element to hit the ball
  
  CONFIGURATION PARAMETERS YOU CAN ADJUST:
  - Wheel radius: Change the "radius" in wheel cylinders (default: 0.1m)
  - Robot size: Modify base_link box dimensions (default: 0.6 x 0.4 x 0.2m)
  - Camera height: Adjust camera_link origin z-value (default: 0.15m above base)
  - Camera field of view: Modify horizontal_fov in camera sensor (default: 1.3962634 rad ~80 degrees)
  - Max velocity: Change max_vel in diff_drive plugin (default: 2.0 m/s)
  - Wheel separation: Modify wheel_separation in diff_drive plugin (default: 0.5m)
-->
<robot name="ball_hitting_robot" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- Define colors for visualization -->
  <material name="blue">
    <color rgba="0.2 0.2 0.8 1.0"/>
  </material>
  
  <material name="black">
    <color rgba="0.1 0.1 0.1 1.0"/>
  </material>
  
  <material name="white">
    <color rgba="0.9 0.9 0.9 1.0"/>
  </material>
  
  <material name="grey">
    <color rgba="0.5 0.5 0.5 1.0"/>
  </material>

  <!-- Base footprint (reference frame on the ground) -->
  <link name="base_footprint"/>

  <!-- Base link - main body of the robot -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.6 0.4 0.2"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.6 0.4 0.2"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="100.0"/>
      <inertia ixx="0.1" ixy="0.0" ixz="0.0"
               iyy="0.1" iyz="0.0"
               izz="0.1"/>
    </inertial>
  </link>

  <!-- Joint connecting footprint to base -->
  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
  </joint>

  <!-- Left wheel -->
  <link name="left_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.5707963 0 0"/>
      <geometry>
        <cylinder radius="0.1" length="0.05"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5707963 0 0"/>
      <geometry>
        <cylinder radius="0.1" length="0.05"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="1.5707963 0 0"/>
      <mass value="0.5"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0"
               iyy="0.001" iyz="0.0"
               izz="0.001"/>
    </inertial>
  </link>

  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <origin xyz="-0.15 0.25 -0.1" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- Right wheel -->
  <link name="right_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.5707963 0 0"/>
      <geometry>
        <cylinder radius="0.1" length="0.05"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5707963 0 0"/>
      <geometry>
        <cylinder radius="0.1" length="0.05"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="1.5707963 0 0"/>
      <mass value="0.5"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0"
               iyy="0.001" iyz="0.0"
               izz="0.001"/>
    </inertial>
  </link>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="-0.15 -0.25 -0.1" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- Caster wheel (front support) -->
  <link name="caster_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.05"/>
      </geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.05"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0"
               iyy="0.0001" iyz="0.0"
               izz="0.0001"/>
    </inertial>
  </link>

  <joint name="caster_wheel_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_wheel"/>
    <origin xyz="0.25 0 -0.15" rpy="0 0 0"/>
  </joint>

  <!-- Pusher/Bumper - the element that hits the ball -->
  <link name="pusher">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 0.3 0.15"/>
      </geometry>
      <material name="white"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 0.3 0.15"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.3"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0"
               iyy="0.001" iyz="0.0"
               izz="0.001"/>
    </inertial>
  </link>

  <joint name="pusher_joint" type="fixed">
    <parent link="base_link"/>
    <child link="pusher"/>
    <origin xyz="0.325 0 -0.025" rpy="0 0 0"/>
  </joint>

  <!-- Camera link -->
  <link name="camera_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 0.05 0.05"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 0.05 0.05"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0"
               iyy="0.0001" iyz="0.0"
               izz="0.0001"/>
    </inertial>
  </link>

  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="0.3 0 0.15" rpy="0 0 0"/>
  </joint>

  <!-- Camera optical frame (standard ROS camera orientation) -->
  <link name="camera_optical_link"/>
  
  <joint name="camera_optical_joint" type="fixed">
    <parent link="camera_link"/>
    <child link="camera_optical_link"/>
    <origin xyz="0 0 0" rpy="-1.5707963 0 -1.5707963"/>
  </joint>

  <!-- Gazebo-specific elements -->
  <gazebo reference="base_link">
    <material>Gazebo/Blue</material>
  </gazebo>

  <gazebo reference="left_wheel">
    <material>Gazebo/Black</material>
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
  </gazebo>

  <gazebo reference="right_wheel">
    <material>Gazebo/Black</material>
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
  </gazebo>

  <gazebo reference="caster_wheel">
    <material>Gazebo/Grey</material>
    <mu1>0.1</mu1>
    <mu2>0.1</mu2>
  </gazebo>

  <gazebo reference="pusher">
    <material>Gazebo/White</material>
  </gazebo>

  <gazebo reference="camera_link">
    <material>Gazebo/Black</material>
    
    <!-- Camera sensor plugin 
         ADJUSTABLE PARAMETERS:
         - update_rate: How often camera captures (Hz) - increase for faster detection
         - horizontal_fov: Field of view in radians (1.3962634 = ~80 degrees)
         - image width/height: Resolution - higher = more detail but slower
    -->
    <sensor name="camera" type="camera">
      <update_rate>30</update_rate>
      <visualize>true</visualize>
      <camera name="camera">
        <horizontal_fov>1.3962634</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.1</near>
          <far>100</far>
        </clip>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.007</stddev>
        </noise>
      </camera>
      
      <!-- Camera sensor: ignition will provide camera data. Removed the
           classic gazebo_ros camera plugin (libgazebo_ros_camera.so) because
           it is incompatible with ros_gz_sim / Ignition. The sensor itself
           remains and will be available to Gazebo; ros_gz_bridge will be
           used to forward the images to ROS2 topics. -->
    </sensor>
  </gazebo>

  <!-- Differential drive plugin 
       ADJUSTABLE CONTROL PARAMETERS:
       - wheel_separation: Distance between wheels (default 0.5m)
       - wheel_diameter: Diameter of wheels (default 0.2m = radius 0.1m * 2)
       - max_wheel_torque: Maximum torque (N⋅m) - increase for more power
       - max_wheel_acceleration: Max acceleration (rad/s²) - increase for faster response
       - command_topic: Topic to receive velocity commands (default /cmd_vel)
       - publish_rate: How often to publish odometry (Hz)
  -->
  <!-- The classic gazebo_ros diff drive plugin was removed because it is
       incompatible with ros_gz_sim (Ignition). The robot's differential
       drive will be provided to ignition via an Ignition system plugin in
       the SDF model `models/robot_gz/model.sdf` which is spawned by the
       launch file when using ros_gz_sim. We keep the URDF for
       robot_state_publisher (TF) while the SDF model handles simulation
       systems (physics, sensors, drive). -->

</robot>